# Managed by Ansible — KRaft single broker (lab)
process.roles=broker,controller
node.id={{ kafka_node_id }}

controller.quorum.voters={{ kafka_node_id }}@{{ kafka_broker_host }}:{{ kafka_controller_port }}

listeners=PLAINTEXT://{{ kafka_listen_address }}:{{ kafka_broker_port }},CONTROLLER://{{ kafka_listen_address }}:{{ kafka_controller_port }}
advertised.listeners=PLAINTEXT://{{ kafka_broker_host }}:{{ kafka_broker_port }}
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
controller.listener.names=CONTROLLER
inter.broker.listener.name=PLAINTEXT

log.dirs={{ kafka_log_dir }}

num.partitions=3
default.replication.factor=1
offsets.topic.replication.factor=1
transaction.state.log.replication.factor=1
transaction.state.log.min.isr=1

log.retention.hours={{ kafka_log_retention_hours }}
log.cleanup.policy=delete

auto.create.topics.enable=false
